<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-ingredients-table.xml" author="devjoaopr">
        <createTable tableName="ingredient">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>

            <column name="category" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="unit" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>

            <column name="stock_quantity" type="DECIMAL(10,3)">
                <constraints nullable="false"/>
            </column>

            <column name="minimum_stock" type="DECIMAL(10,3)">
                <constraints nullable="false"/>
            </column>

            <column name="cost_per_unit" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>
</databaseChangeLog>