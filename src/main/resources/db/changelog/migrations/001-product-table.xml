<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-product-table" author="devjoaopr">
        <createTable tableName="product">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>

            <column name="category" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="recipe_yield" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="profit_margin" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="sale_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="is_available" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

</databaseChangeLog>